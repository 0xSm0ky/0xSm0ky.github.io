---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tagMap = new Map<string, typeof posts>();
  for (const p of posts) {
    for (const t of p.data.tags) {
      if (!tagMap.has(t)) tagMap.set(t, []);
      tagMap.get(t)!.push(p);
    }
  }
  return Array.from(tagMap.entries()).map(([tag, tagPosts]) => ({
    params: { tag },
    props: {
      tag,
      posts: tagPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`} description={`Posts tagged ${tag}`}>
  <h1>#{tag}</h1>
  <p class="muted">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  <ul class="post-list">
    {posts.map((p) => (
      <PostCard
        slug={p.slug}
        title={p.data.title}
        description={p.data.description}
        date={p.data.date}
        lang={p.data.lang}
        tags={p.data.tags}
      />
    ))}
  </ul>
</BaseLayout>

---
// Pure CSS toggle: buttons set [data-active-lang] on the nearest .post-list.
---
<div class="lang-filter" role="group" aria-label="تصفية حسب اللغة">
  <button type="button" data-lang="all" aria-pressed="true">الكل</button>
  <button type="button" data-lang="ar" aria-pressed="false">عربي</button>
  <button type="button" data-lang="en" aria-pressed="false">EN</button>
</div>

<script is:inline>
  (() => {
    const filter = document.currentScript.previousElementSibling;
    const list = document.querySelector('.post-list');
    if (!filter || !list) return;
    filter.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-lang]');
      if (!btn) return;
      const lang = btn.dataset.lang;
      filter.querySelectorAll('button').forEach((b) =>
        b.setAttribute('aria-pressed', String(b === btn))
      );
      if (lang === 'all') list.removeAttribute('data-active-lang');
      else list.setAttribute('data-active-lang', lang);
    });
  })();
</script>

---
interface Props {
  slug: string;
  title: string;
  description?: string;
  date: Date;
  lang: 'en' | 'ar';
}
const { slug, title, description, date, lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dateStr = date.toISOString().slice(0, 10);
---
<li class="post-card" data-lang={lang}>
  <div class="post-card__meta">
    <span>{dateStr}</span>
  </div>
  <h2 class="post-card__title">
    <a href={`${base}/blog/${slug}/`}>{title}</a>
  </h2>
  {description && <p class="post-card__desc">{description}</p>}
</li>

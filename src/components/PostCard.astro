---
import TagBadge from './TagBadge.astro';

interface Props {
  slug: string;
  title: string;
  description?: string;
  date: Date;
  lang: 'en' | 'ar';
  tags: string[];
}
const { slug, title, description, date, lang, tags } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dateStr = date.toISOString().slice(0, 10);
---
<li class="post-card" data-lang={lang}>
  <div class="post-card__meta">
    <span>{dateStr}</span>
    <span class="lang-badge">{lang}</span>
    {tags.slice(0, 3).map((t) => <TagBadge tag={t} />)}
  </div>
  <h2 class="post-card__title">
    <a href={`${base}/blog/${slug}/`}>{title}</a>
  </h2>
  {description && <p class="post-card__desc">{description}</p>}
</li>
